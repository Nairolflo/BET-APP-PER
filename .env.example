# Flask
FLASK_ENV=production
SECRET_KEY=change_me_please_use_random_string

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/valuebetfc

# API-Football (https://www.api-football.com)
FOOTBALL_API_KEY=your_api_football_key_here
FOOTBALL_API_HOST=v3.football.api-sports.io

# The Odds API (https://the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Detection settings
VALUE_BET_EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.25
MAX_STAKE_UNITS=3.0
UNIT_SIZE=10.0

# Leagues to monitor (comma-separated API-Football league IDs)
MONITORED_LEAGUES=39,140,78,61,135